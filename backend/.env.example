# ===========================
# Market Monitor Backend Environment Variables
# ===========================
# Copy this file to .env and fill in your actual API keys
# All services below offer free tiers for personal use

# Application Settings
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# CORS Settings (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://192.168.64.15:3000

# ===========================
# Stock Data APIs
# ===========================

# Finnhub (Primary - WebSocket + REST)
# Sign up: https://finnhub.io/register
# Free tier: ~60 calls/min, WebSocket real-time US quotes
FINNHUB_API_KEY=your_finnhub_api_key_here

# Financial Modeling Prep (FMP)
# Sign up: https://site.financialmodelingprep.com/developer/docs
# Free tier: 250 calls/day, strong fundamentals & historicals
FMP_API_KEY=your_fmp_api_key_here

# Alpha Vantage (Backup)
# Sign up: https://www.alphavantage.co/support/#api-key
# Free tier: 25 calls/day
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# Twelve Data (Backup)
# Sign up: https://twelvedata.com/pricing
# Free tier: 800 calls/day
TWELVE_DATA_API_KEY=your_twelve_data_api_key_here

# ===========================
# Crypto Data APIs
# ===========================

# CoinGecko (Primary)
# Sign up: https://www.coingecko.com/en/api/pricing
# Demo tier: 30-50 calls/min, 10k calls/month
COINGECKO_API_KEY=your_coingecko_api_key_here

# Note: Binance public API needs no key for market data
# CCXT will be used for unified crypto access

# ===========================
# Cache & Rate Limiting
# ===========================

# Cache TTL (seconds)
CACHE_TTL_QUOTES=60
CACHE_TTL_HISTORICAL=3600
CACHE_TTL_FUNDAMENTALS=86400

# Rate Limit Settings
RATE_LIMIT_ENABLED=true
RATE_LIMIT_CALLS_PER_MINUTE=50

# ===========================
# WebSocket Settings
# ===========================
WS_PING_INTERVAL=30
WS_PING_TIMEOUT=10
WS_MAX_CONNECTIONS=100

# ===========================
# Database (Optional - for future use)
# ===========================
# DATABASE_URL=sqlite:///./market_monitor.db
